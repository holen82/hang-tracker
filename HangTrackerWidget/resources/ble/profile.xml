<?xml version="1.0" encoding="UTF-8"?>
<!--
    BLE Peripheral profile for HangTracker widget.
    The watch acts as a GATT server; the PWA connects as a client.
-->
<bleProfile>
    <peripheral
        name="HangTracker"
        uuid="12ab3456-7890-cdef-0123-456789abcdef">

        <service uuid="12ab3456-7890-cdef-0123-456789abcdef">

            <!-- TARGET_CHAR: current target seconds, uint16 LE -->
            <characteristic
                uuid="12ab3456-0001-cdef-0123-456789abcdef"
                read="true"
                write="true"/>

            <!-- LEVEL_CHAR: active level 1/2/3, uint8 -->
            <characteristic
                uuid="12ab3456-0002-cdef-0123-456789abcdef"
                read="true"
                write="true"/>

            <!-- SESSIONS_CHAR: pending sessions, read-only, up to 512 bytes -->
            <characteristic
                uuid="12ab3456-0003-cdef-0123-456789abcdef"
                read="true"
                write="false"/>

            <!-- COMMAND_CHAR: write-without-response, 1 byte commands -->
            <characteristic
                uuid="12ab3456-0004-cdef-0123-456789abcdef"
                read="false"
                write="true"
                writeType="writeWithoutResponse"/>

        </service>
    </peripheral>
</bleProfile>
